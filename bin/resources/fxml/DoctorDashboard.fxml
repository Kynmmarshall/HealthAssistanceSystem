<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DoctorDashboardController">
    <VBox.margin>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </VBox.margin>
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <HBox alignment="CENTER_RIGHT" spacing="10" onMousePressed="#handleTitleBarPressed" onMouseDragged="#handleTitleBarDragged">
        <ImageView fitHeight="34" fitWidth="34" preserveRatio="true" styleClass="appIcon">
            <image>
                <Image url="@../images/logo.png" />
            </image>
        </ImageView>
        <Label fx:id="welcomeLabel" styleClass="welcomeLabel" HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Refresh" onAction="#refreshData" styleClass="toggle-button"/>
        <Button text="Fullscreen" onAction="#toggleFullscreen" styleClass="toggle-button"/>
        <Button text="Logout" onAction="#handleLogout" styleClass="exit-button"/>
    </HBox>
    <HBox spacing="20">
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <Label text="📋 Upcoming Appointments" styleClass="sectionTitle"/>
            <TableView fx:id="appointmentTable" prefHeight="250">
                <columns>
                    <TableColumn text="Patient" fx:id="colPatient"/>
                    <TableColumn text="Date &amp; Time" fx:id="colDateTime"/>
                    <TableColumn text="Status" fx:id="colStatus"/>
                </columns>
            </TableView>
        </VBox>
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <Label text="👨‍⚕️ My Profile" styleClass="sectionTitle"/>
            <TextField fx:id="nameField" promptText="Full Name"/>
            <TextField fx:id="specField" promptText="Specialization"/>
            <TextArea fx:id="scheduleField" promptText="Schedule (e.g., Mon 9-12, Wed 14-17)" prefHeight="80"/>
            <Button text="Save Changes" onAction="#updateProfile" styleClass="saveButton"/>
        </VBox>
    </HBox>

    <VBox spacing="10">
        <Label text="📝 Create Health Record" styleClass="sectionTitle"/>
        <Label text="Select an appointment first, then enter the patient diagnosis and prescription." wrapText="true"/>
        <TextArea fx:id="diagnosisArea" promptText="Diagnosis" prefHeight="80"/>
        <TextArea fx:id="prescriptionArea" promptText="Prescription" prefHeight="80"/>
        <Button text="Save Health Record" onAction="#addHealthRecord" styleClass="saveButton"/>
    </VBox>
</VBox>